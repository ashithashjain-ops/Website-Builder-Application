# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000/api
CORS_ORIGINS=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-another-random-string
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth (optional — leave placeholder if not configured)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (optional — not yet implemented)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email / SMTP
# EMAIL_DELIVERY_MODE: 'smtp' for real emails, 'console' for dev (prints OTP to terminal)
EMAIL_DELIVERY_MODE=console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Stackly
SMTP_FROM_EMAIL=

# SMS
# SMS_PROVIDER: 'mock' (dev), 'twilio', or 'textlocal'
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TEXTLOCAL_API_KEY=
TEXTLOCAL_SENDER=

# Razorpay (Primary Payment)
PAYMENT_PRIMARY_PROVIDER=razorpay
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# E-commerce checkout totals are calculated server-side.
ECOMMERCE_TAX_RATE=0
ECOMMERCE_SHIPPING_COST=0
ECOMMERCE_WORKSPACE_ID=

# Stripe (Secondary — optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# AWS S3 (Publishing — optional)
# AWS_S3_BUCKET=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
